{
    "manifest_version": 3,
    "name": "Adblock Web Extension",
    "description": "Blocks ads and reports statistics to the app.",
    "version": "1.0",

    "background": {
        "scripts": ["background.js"]
    },

    "content_scripts": [{
        "js": ["content.js"],
        "matches": ["<all_urls>"],
        "run_at": "document_start"
    }],

    "host_permissions": ["<all_urls>"],

    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "nativeMessaging"
    ]
}
